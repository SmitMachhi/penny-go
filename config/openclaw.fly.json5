{
  "gateway": {
    "mode": "local",
    "auth": { "mode": "token" },
    "port": 18789,
    "bind": "loopback"
  },
  "session": {
    "reset": { "mode": "idle", "idleMinutes": 10080 },
    "writeLock": {
      "acquireTimeoutMs": 120000,
      "maxHoldMs": 3600000,
      "staleMs": 3600000
    }
  },
  "agents": {
    "defaults": {
      "timeoutSeconds": 3600,
      "models": {
        "fireworks/accounts/fireworks/models/deepseek-v4-flash": {
          "alias": "DeepSeek V4 Flash (Fireworks)",
          "params": {
            "reasoning": { "effort": "high" },
            "max_tokens": 16384
          }
        },
        "fireworks/accounts/fireworks/models/kimi-k2p7-code": {
          "alias": "Kimi K2.7 Code (Fireworks)",
          "params": {
            "max_tokens": 16384
          }
        }
      },
      "model": {
        "primary": "fireworks/accounts/fireworks/models/deepseek-v4-flash",
        "fallbacks": ["fireworks/accounts/fireworks/models/kimi-k2p7-code"]
      },
      "workspace": "/app/workspace",
      "memorySearch": {
        "sources": ["memory"]
      }
    }
  },
  "commands": {
    "nativeSkills": false
  },
  "tools": {
    "allow": [
      "search_corpus",
      "read_official_source",
      "publish_funding_brief",
      "web_search"
    ],
    "web": {
      "search": { "provider": "exa" },
      "fetch": { "enabled": false }
    }
  },
  "plugins": {
    "enabled": true,
    "allow": ["fireworks", "exa", "penny-tools"],
    "load": {
      "paths": ["/app/plugin"]
    },
    "entries": {
      "fireworks": { "enabled": true },
      "exa": { "enabled": true },
      "penny-tools": {
        "enabled": true,
        "config": {
          "corpusPath": "/app/database/data/funding/curated/verified-programs.jsonl",
          "firecrawlApiKey": "env:FIRECRAWL_API_KEY",
          "pythonPath": "/app/.venv/bin/python",
          "repoRoot": "/app"
        }
      }
    }
  }
}
