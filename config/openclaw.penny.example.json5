{
  "session": {
    // Use idle reset instead of daily 4 AM reset so active Penny transcripts survive across days.
    // OpenClaw requires a positive value here; 10080 minutes is one idle week.
    "reset": { "mode": "idle", "idleMinutes": 10080 }
  },
  "agents": {
    "defaults": {
      "models": {
        "deepseek/deepseek-v4-flash": {
          "alias": "DeepSeek V4 Flash",
          "params": {
            // Keep Penny on the first-party DeepSeek endpoint; do not silently
            // fall back to another OpenRouter-hosted provider.
            "provider": { "order": ["deepseek"], "allow_fallbacks": false },
            "reasoning": { "effort": "high" },
            "max_tokens": 16384
          }
        }
      },
      "model": { "primary": "deepseek/deepseek-v4-flash" },
      "workspace": "/ABSOLUTE_PATH_TO_REPO/workspace",
      "skills": ["penny-consultation-modes", "penny-funding", "penny-artifacts", "stop-slop"],
      // Keep memory search scoped to workspace Markdown only — do NOT add "sessions"
      // and do NOT enable experimental.sessionMemory (cross-session transcript indexing).
      "memorySearch": {
        "sources": ["memory"]
      }
    }
  },
  "tools": {
    "allow": [
      "search_corpus",
      "read_official_source",
      "publish_funding_brief",
      "web_search"
    ],
    "web": {
      "search": { "provider": "exa" },
      "fetch": { "enabled": false }
    }
  },
  "plugins": {
    "entries": {
      "exa": { "enabled": true },
      "penny-tools": {
        "enabled": true,
        "config": {
          "corpusPath": "/ABSOLUTE_PATH_TO_REPO/database/data/funding/curated/verified-programs.jsonl",
          // Optional when EXA_API_KEY is present in the Gateway environment.
          // Used only as a same-URL fallback when Crawl4AI hits anti-bot protection.
          "exaApiKey": "env:EXA_API_KEY",
          "pythonPath": "/ABSOLUTE_PATH_TO_REPO/.venv/bin/python",
          "repoRoot": "/ABSOLUTE_PATH_TO_REPO"
        }
      }
    }
  }
}
