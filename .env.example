# Copy to ~/.openclaw/.env for OpenClaw gateway (never commit real keys).
FIREWORKS_API_KEY=
EXA_API_KEY=
FIRECRAWL_API_KEY=

# Paths for Penny tooling (optional; plugin config overrides these).
PENNY_REPO_ROOT=/absolute/path/to/penny-go
PENNY_CORPUS_PATH=/absolute/path/to/penny-go/database/data/funding/curated/verified-programs.jsonl
PENNY_PYTHON=/absolute/path/to/penny-go/.venv/bin/python

# Python tooling: create .venv then `pip install -r tools/requirements-read-official-source.txt` + `crawl4ai-setup`.
