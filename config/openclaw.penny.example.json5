{
  "session": {
    // Use idle reset instead of daily 4 AM reset so active Penny transcripts survive across days.
    // OpenClaw requires a positive value here; 10080 minutes is one idle week.
    "reset": { "mode": "idle", "idleMinutes": 10080 }
  },
  "agents": {
    "defaults": {
      // OpenRouter default. To switch back to DeepSeek later, set this to
      // "deepseek/deepseek-v4-flash" and provide DEEPSEEK_API_KEY again.
      "models": {
        "openrouter/moonshotai/kimi-k2.6": {
          "alias": "Kimi K2.6 (WandB FP4)",
          "params": {
            // Pin OpenRouter to the WandB FP4 endpoint; do not silently fall back
            // to another provider if that endpoint is unavailable.
            "provider": { "order": ["wandb/fp4"], "allow_fallbacks": false },
            "reasoning": { "effort": "high" },
            "max_tokens": 16384
          }
        }
      },
      "model": { "primary": "openrouter/moonshotai/kimi-k2.6" },
      "workspace": "/ABSOLUTE_PATH_TO_REPO/workspace",
      "skills": ["penny-consultation-modes", "penny-funding", "penny-artifacts", "stop-slop"],
      // Keep memory search scoped to workspace Markdown only — do NOT add "sessions"
      // and do NOT enable experimental.sessionMemory (cross-session transcript indexing).
      "memorySearch": {
        "sources": ["memory"]
      }
    }
  },
  "tools": {
    "allow": ["search_corpus", "read_official_source", "create_funding_brief", "web_search"],
    "web": {
      "search": { "provider": "exa" },
      "fetch": { "enabled": false }
    }
  },
  "plugins": {
    "entries": {
      "exa": { "enabled": true },
      "penny-tools": {
        "enabled": true,
        "config": {
          "corpusPath": "/ABSOLUTE_PATH_TO_REPO/database/data/funding/curated/verified-programs.jsonl",
          "pythonPath": "/ABSOLUTE_PATH_TO_REPO/.venv/bin/python",
          "repoRoot": "/ABSOLUTE_PATH_TO_REPO"
        }
      }
    }
  }
}
